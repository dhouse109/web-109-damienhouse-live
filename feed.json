---
layout: null
sitemap: false
---
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": {{ site.title | jsonify }},
  "home_page_url": "{{ site.url | append: site.baseurl }}/",
  "feed_url": "{{ site.url | append: site.baseurl }}/feed.json",
  "description": {{ site.description | default: "Recent content" | jsonify }},
  "items": [
    {% for post in site.posts limit: 10 %}
    {
      "id": "{{ site.url | append: site.baseurl }}{{ post.id }}",
      "url": "{{ site.url | append: site.baseurl }}{{ post.url }}",
      "title": {{ post.title | jsonify }},
      "content_html": {{ post.content | jsonify }},
      "summary": {{ post.excerpt | strip_html | truncatewords: 30 | jsonify }},
      "date_published": "{{ post.date | date_to_xmlschema }}"
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}